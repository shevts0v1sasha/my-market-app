<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="1" author="shevtsovdev">
        <preConditions onFail="MARK_RAN">
            <and>
                <not>
                    <tableExists tableName="items"/>
                </not>
                <dbms type="postgresql"/>
            </and>
        </preConditions>
        <createTable tableName="items">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_items" nullable="false"/>
            </column>
            <column name="title" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="img_path" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="count" type="int">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="items" indexName="idx_items_title">
            <column name="title"/>
        </createIndex>
        <createIndex tableName="items" indexName="idx_items_price">
            <column name="price"/>
        </createIndex>

        <rollback>
            <dropTable tableName="items"/>
        </rollback>
    </changeSet>
</databaseChangeLog>